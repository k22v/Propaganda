# Database
DATABASE_URL=sqlite+aiosqlite:///./lms.db
# Для PostgreSQL: postgresql+asyncpg://user:password@localhost/lms_db

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REMEMBER_ME_EXPIRE_DAYS=7

# CORS (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Email (для будущей отправки писем)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# Optional: Redis (для кэширования и rate limiting)
# REDIS_URL=redis://localhost:6379
